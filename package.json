{
  "name": "@mohansilambu/menu-admin",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist/menu-admin.es.js",
    "dist/menu-admin.umd.js",
    "dist/index.d.ts"
  ],
  "main": "dist/menu-admin.umd.js",
  "module": "dist/menu-admin.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/menu-admin.es.js",
      "require": "./dist/menu-admin.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:umd && npm run build:esm && npm run build:types",
    "build:umd": "vite build --config vite.umd.config.ts",
    "build:esm": "vite build --config vite.esm.config.ts",
    "build:types": "cp src/index.d.ts dist/index.d.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.1.0"
  }
}